<?xml version="1.0" encoding="utf-8"?>
<animated-selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="false"
        android:state_checked="true"
        android:drawable="@drawable/radio_hw_vector_checked_disable_bg" />
    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:drawable="@drawable/radio_hw_vector_unchecked_disable_bg" />
    <item
        android:state_checked="true"
        android:id="@id/checked"
        android:drawable="@drawable/radio_hw_vector_checked_bg" />
    <item
        android:id="@id/unchecked"
        android:drawable="@drawable/radio_hw_vector_unchecked_bg" />
    <transition
        android:drawable="@drawable/radio_hw_animated_vector_off2on"
        android:toId="@id/checked"
        android:fromId="@id/unchecked" />
    <transition
        android:drawable="@drawable/radio_hw_animated_vector_on2off"
        android:toId="@id/unchecked"
        android:fromId="@id/checked" />
</animated-selector>