<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="false">
        <shape
            android:shape="rectangle">
            <corners
                android:radius="@dimen/hw_kid_button_drawable_normal_only_font_normal_radius" />
            <solid
                android:color="@color/hw_kid_button_drawable_normal_only_font" />
            <stroke
                android:color="@color/hw_kid_button_drawable_normal_only_font" />
        </shape>
    </item>
    <item
        android:state_pressed="true">
        <layer-list>
            <item>
                <shape
                    android:shape="rectangle">
                    <corners
                        android:radius="@dimen/hw_kid_button_drawable_normal_only_font_normal_radius" />
                    <solid
                        android:color="@color/hw_kid_button_drawable_normal_only_font" />
                    <stroke
                        android:color="@color/hw_kid_button_drawable_normal_only_font" />
                </shape>
            </item>
            <item>
                <shape
                    android:shape="rectangle">
                    <corners
                        android:radius="@dimen/hw_kid_button_drawable_normal_only_font_normal_radius" />
                    <solid
                        android:color="@color/hw_kid_button_drawable_public_color" />
                    <stroke
                        android:color="@color/hw_kid_button_drawable_public_color" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>